---
import type { Dict } from "@/libs/i18n/es";
interface Props {
  t: Dict;
}
const { t } = Astro.props;
---

<dialog class="guide js-guide-dialog" aria-labelledby="guideTitle">
  <div class="guide__head">
    <h2 class="guide__title" id="guideTitle">{t.guide.title}</h2>
    <button type="button" class="guide__close js-guide-close" aria-label={t.history.close} title={t.history.close}>&times;</button>
  </div>

  <div class="guide__body">
    <p class="guide__lead">{t.guide.lead}</p>

    <section class="guide__section">
      <h3 class="guide__section-title">{t.guide.modesTitle}</h3>
      <ul class="guide__list">
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="13" r="8"></circle><line x1="12" y1="13" x2="12" y2="9"></line><line x1="9" y1="2" x2="15" y2="2"></line></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.stopwatchTerm}</span>
            <p class="guide__desc">{t.guide.stopwatchDesc}</p>
          </span>
        </li>
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="13" r="8"></circle><path d="M12 13V9"></path><path d="M12 13l3.5 2"></path></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.timerTerm}</span>
            <p class="guide__desc">{t.guide.timerDesc}</p>
          </span>
        </li>
      </ul>
    </section>

    <section class="guide__section">
      <h3 class="guide__section-title">{t.guide.durationTitle}</h3>
      <ul class="guide__list">
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16"></path><path d="M4 12h10"></path><path d="M4 17h7"></path></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.durationTerm}</span>
            <p class="guide__desc" set:html={t.guide.durationDesc}></p>
          </span>
        </li>
      </ul>
    </section>

    <section class="guide__section">
      <h3 class="guide__section-title">{t.guide.buttonsTitle}</h3>
      <ul class="guide__list">
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="2"></rect><rect x="11" y="11" width="8" height="5" rx="1" fill="currentColor"></rect></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.pipTerm}</span>
            <p class="guide__desc">{t.guide.pipDesc}</p>
          </span>
        </li>
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.themeTerm}</span>
            <p class="guide__desc">{t.guide.themeDesc}</p>
          </span>
        </li>
      </ul>
    </section>

    <section class="guide__section">
      <h3 class="guide__section-title">{t.guide.whyTitle}</h3>
      <ul class="guide__list">
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 12s3.6-6 10-6 10 6 10 6-3.6 6-10 6-10-6-10-6z"></path><circle cx="12" cy="12" r="2.6"></circle></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.inTabTerm}</span>
            <p class="guide__desc">{t.guide.inTabDesc}</p>
          </span>
        </li>
        <li class="guide__item">
          <span class="guide__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h8v12H3z"></path><path d="M14 9l4 3-4 3"></path><path d="M21 6v12"></path></svg>
          </span>
          <span>
            <span class="guide__term">{t.guide.awayTerm}</span>
            <p class="guide__desc">{t.guide.awayDesc}</p>
          </span>
        </li>
      </ul>
    </section>

    <p class="guide__note">
      <span aria-hidden="true">⚠️</span>
      <span set:html={t.guide.note}></span>
    </p>
  </div>
</dialog>
